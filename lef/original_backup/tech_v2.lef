    PARALLELRUNLENGTH 0.004 10.004 
    WIDTH 0.004 0.23 0.23 
    WIDTH 10.004 0.23 0.6 ;
  SPACING 0.23 SAMENET ;
  RESISTANCE RPERSQ 0.078 ;
  MINIMUMDENSITY 30 ;
  ANTENNAMODEL OXIDE1 ;
  ANTENNAAREARATIO 400 ;
END METAL1

