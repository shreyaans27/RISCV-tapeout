VERSION 5.7 ;
BUSBITCHARS "[]" ;
DIVIDERCHAR "/" ;

PROPERTYDEFINITIONS
  MACRO lastSavedExtractCounter INTEGER ;
  LAYER LEF58_TYPE STRING ;
  LAYER LEF58_ENCLOSURE STRING ;
  LAYER LEF58_SPACING STRING ;
  LAYER LEF58_WIDTH STRING ;
END PROPERTYDEFINITIONS

UNITS
  CAPACITANCE PICOFARADS 1 ;
  DATABASE MICRONS 1000 ;
END UNITS
MANUFACTURINGGRID 0.001 ;
LAYER OVERLAP
  TYPE OVERLAP ;
END OVERLAP

# High density, single height
SITE core
  SYMMETRY Y ;
  CLASS CORE ;
  SIZE 0.73 BY 4.04 ;
END core






LAYER PWELL
  TYPE MASTERSLICE ;
  PROPERTY LEF58_TYPE "TYPE PWELL ;" ;
END PWELL

LAYER NWELL
  TYPE MASTERSLICE ;
  PROPERTY LEF58_TYPE "TYPE NWELL ;" ;
  PROPERTY LEF58_SPACING "SPACING 1.4 ;" ;
  PROPERTY LEF58_WIDTH "WIDTH 0.86 ;" ;
END NWELL

LAYER NIMP
  TYPE IMPLANT ;
  WIDTH 0.44 ;
  SPACING 0.44 ;
  AREA 0.3844 ;
END NIMP

LAYER PIMP
  TYPE IMPLANT ;
  WIDTH 0.44 ;
  SPACING 0.44 ;
  AREA 0.3844 ;
END PIMP

LAYER DIFF
  TYPE MASTERSLICE ;
  PROPERTY LEF58_TYPE "TYPE DIFFUSION ;" ;
  PROPERTY LEF58_SPACING "SPACING 0.28 ;" ;
  PROPERTY LEF58_WIDTH "WIDTH 0.22 ;" ;
END DIFF

LAYER POLY1
  TYPE MASTERSLICE ;
END POLY1

LAYER CONT
  TYPE CUT ;
  SPACING 0.25 ;
  SPACING 0.28 ADJACENTCUTS 3 WITHIN 0.3 ;
  WIDTH 0.22 ;
  ENCLOSURE ABOVE 0.005 0.06 ;
  ANTENNAMODEL OXIDE1 ;
    ANTENNAAREARATIO 10 ;
END CONT

LAYER METAL1
